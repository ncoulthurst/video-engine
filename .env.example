# ─── LLM providers ───────────────────────────────────────────────────────────

# Groq — fast, free-tier Llama 3.3 70B used by research, data, and analysis agents.
# Sign up: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini 2.5 Flash Lite — used by script_agent and storyboard_agent for
# creative generation, and as a fallback when Groq hits rate limits.
# Sign up: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ─── Voice / narration ───────────────────────────────────────────────────────

# ElevenLabs — text-to-speech narration. Skippable: set SKIP_VOICEOVER: true in
# the per-project context.md to bypass entirely.
# Sign up: https://elevenlabs.io/app/speech-synthesis
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs voice ID — pick one from your voice library or the public catalogue.
ELEVENLABS_VOICE_ID=your_voice_id_here

# ─── Football data ───────────────────────────────────────────────────────────

# football-data.org — match fixtures, standings, scorers (free tier, ~10 req/min).
# Sign up: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# RapidAPI — used for additional football data endpoints (transfer history, etc).
# Sign up: https://rapidapi.com/ and subscribe to a football API of your choice.
RAPIDAPI_KEY=your_rapidapi_key_here

# Guardian Open Platform — news search for research_agent.
# 'test' is Guardian's public dev key (~12 calls/sec) and works fine for
# low-volume use. For production, register at:
# https://open-platform.theguardian.com/access/
GUARDIAN_KEY=test

# SerpAPI — web search fallback for research_agent (optional; agent returns
# empty results if unset rather than failing).
# Sign up: https://serpapi.com/users/sign_up
SERPAPI_KEY=your_serpapi_key_here

# ─── Paths ───────────────────────────────────────────────────────────────────

# Path to the separate Remotion (React) rendering project. The engine shells
# out to this directory to render graphics. Required.
REMOTION_PROJECT_PATH=/absolute/path/to/your/remotion/project

# Optional override for the engine root. Defaults to the directory containing
# server.py — only set if you've split the engine across non-standard paths.
# ENGINE_ROOT=/absolute/path/to/this/repo
